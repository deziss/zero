   "source": [
    "# 08 — MVP v1: Adaptive Simulation Depth with AI Prediction\n",
    "\n",
    "**Adaptive Multiscale Biological Simulation AI**\n",
    "\n",
    "This notebook implements MVP v1: a small-molecule system where AI predicts which atoms need deeper simulation.\n",
    "\n",
    "**Key features:**\n",
    "1. Load a small molecule (water cluster or methane)\n",
    "2. Run MACE model to get node features\n",
    "3. Switch simulation depth per atom\n",
    "4. Compute energy/force with depth-adaptive precision\n",
    "5. Compare accuracy vs. speedup"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "import matplotlib.pyplot as plt\n",
    "from pathlib import Path\n",
    "import sys\n",
    "sys.path.insert(0, str(Path(__file__).parent.parent.parent))\n",
    "from src.sim.deepness.simulation_depth import SimulationDepth, DepthSelector\n",
    "from src.sim.layers.depth_selector import DepthSelectorLayer\n",
    "from src.ml.model.mace import MACE\n",
    "from src.ml.datasets.qm9 import QM9Dataset\n",
    "\n",
    "plt.style.use('seaborn-v0_8-whitegrid')\n",
    "plt.rcParams.update({'font.size': 13})\n",
    "print('Imports successful.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Create a Small Molecule System\n",
    "\n",
    "For MVP v1, we'll use a small water cluster (10-20 water molecules) to avoid overwhelming the system and the available compute."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create a 15-water-molecule cluster\n",
    "n_waters = 15\n",
    "n_atoms = n_waters * 3  # 45 atoms\n",
    "atomic_numbers = [8]*15 + [1]*30  # 15 Oxygens, 30 Hydrogens\n",
    "\n",
    "# Generate initial positions (random cluster)\n",
    "positions = np.random.uniform(-3, 3, (n_atoms, 3))\n",
    "\n",
    "# Organize into water molecules\n",
    "water_positions = []\n",
    "for i in range(n_waters):\n",
    "    ox = positions[i*3]\n",
    "    # Two hydrogens at ~1.0 Angstrom from oxygen\n",
    "    h1 = ox + np.array([1.0, 0.3, 0.0])\n",
    "    h2 = ox + np.array([-0.3, 0.8, 0.5])\n",
    "    water_positions.extend([ox, h1, h2])\n",
    "\n",
    "positions = np.array(water_positions)\n",
    "\n",
    "print(f'System: {n_waters} water molecules = {n_atoms} atoms')\n",
    "print(f'Positions shape: {positions.shape}')\n",
    "print(f'Atomic numbers shape: {len(atomic_numbers)}')\n",
    "print(f'Expected atomic numbers: 15 O at Z=8, 30 H at Z=1')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Run MACE Model for Node Features\n",
    "\n",
    "Use the MACE model to predict energies and get node-level features for depth selection."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Initialize MACE model\n",
    "mace = MACE(\n",
    "    max_degree=4,\n",
    "    max_l=4,\n",
    "    num_interactions=2,\n",
    "    hidden_dim=128,\n",
    "    n_rbf=20,\n",
    "    r_cut=5.0,\n",
    "    cutoff_mult=2.5\n",
    ")\n",
    "\n",
    "# Prepare input tensors\n",
    "atomic_numbers_tensor = torch.tensor(atomic_numbers, dtype=torch.long)\n",
    "positions_tensor = torch.tensor(positions, dtype=torch.float32)\n",
    "\n",
    "# Forward pass\n",
    "print('Running MACE forward pass...')\n",
    "output = mace(atomic_numbers_tensor, positions_tensor)\n",
    "\n",
    "if output is None:\n",
    "    print('MACE forward pass returned None. Check model initialization.')\n",
    "else:\n",
    "    print(f'MACE output type: {type(output)}')\n",
    "    if isinstance(output, dict):\n",
    "        print(f'MACE keys: {list(output.keys())}')\n",
    "    elif isinstance(output, torch.Tensor):\n",
    "        print(f'MACE output shape: {output.shape}')\n",
    "        print(f'MACE output value range: [{output.min():.3f}, {output.max():.3f}]')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Depth Selector — Adaptive Depth Assignment"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Initialize the adaptive depth engine\n",
    "from src.sim.engine.switchoff_engine import SwitchoffEngine\n",
    "\n",
    "engine = SwitchoffEngine(force_threshold=0.5, gradient_threshold=1.0)\n",
    "print('Switchoff Engine initialized.')\n",
    "print(f'Force threshold: {engine.force_threshold}')\n",
    "print(f'Gradient threshold: {engine.gradient_threshold}')\n",
    "\n",
    "# Get node features from MACE (if available)\n",
    "if output is not None:\n",
    "    if isinstance(output, dict) and 'node_features' in output:\n",
    "        node_features = output['node_features']\n",
    "    else:\n",
    "        # Use dummy node features based on atomic number\n",
    "        node_features = torch.zeros(n_atoms, 32)\n",
    "        for i in range(n_atoms):\n",
    "            node_features[i, i % 32] = 1.0  # One-hot encoding\n",
    "else:\n",
    "    node_features = torch.zeros(n_atoms, 32)\n",
    "\n",
    "# Apply depth selector\n",
    "depth_selector = DepthSelectorLayer(hidden_dim=32, n_depths=5)\n",
    "depth_scores, depth_probs = depth_selector(node_features)\n",
    "\n",
    "# Convert to discrete depths\n",
    "depths = torch.floor(depth_scores).long()\n",
    "depths = torch.clamp(depths, 0, 4)\n",
    "\n",
    "print(f\"\\nDepth assignments for {n_atoms} atoms:\")\n",
    "for i, depth in enumerate(depths):\n",
    "    atom_type = 'O' if atomic_numbers[i] == 8 else 'H'\n",
    "    print(f\"  Atom {i:2d} ({atom_type}): depth {depth.item()} ({SimulationDepth.NAMES[depth.item()]})\")\n",
    "\n",
    "# Region statistics\n",
    "depth_counts = {d: int((depths == d).sum().item()) for d in range(5)}\n",
    "print(f\"\\nRegion distribution:\")\n",
    "for d in range(5):\n",
    "    pct = depth_counts[d] / n_atoms * 100\n",
    "    bar = '#' * int(pct / 2)\n",
    "    print(f\"  {SimulationDepth.NAMES[d]:15s}|{' ' * (n_atoms - depth_counts[d])}{'#' * depth_counts[d]} ({depth_counts[d]} atoms, {pct:.1f}%)\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Depth-Adaptive Simulation\n",
    "\n",
    "Run the simulation with adaptive precision."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Run adaptive simulation loop\n",
    "n_timesteps = 50\n",
    "dt = 0.001  # 1 femtosecond timestep\n",
    "masses = np.array([16.0 if z == 8 else 1.0 for z in atomic_numbers])\n",
    "forces = np.zeros((n_atoms, 3))\n",
    "velocities = np.zeros((n_atoms, 3))\n",
    "energies = []\n",
    "depth_history = {d: [] for d in range(5)}\n",
    "\n",
    "# Calculate initial forces (simplified LJ for demonstration)\n",
    "for i in range(n_atoms):\n",
    "    for j in range(i+1, n_atoms):\n",
    "        dr = positions[i] - positions[j]\n",
    "        r = np.linalg.norm(dr)\n",
    "        if r < 5.0:  # Cutoff\n",
    "            # LJ force\n",
    "            sig2 = 1.0\n",
    "            eps = 0.1\n",
    "            r6 = r**6\n",
    "            r12 = r6**2\n",
    "            if r > 1e-8:\n",
    "                f_mag = 24 * eps * (2 * sig2 / r12 - sig2 / r6) / r\n",
    "                forces[i] -= f_mag * dr\n",
    "                forces[j] += f_mag * dr\n",
    "\n",
    "# Velocity-Verlet integration with adaptive depth\n",
    "for t in range(n_timesteps):\n",
    "    # Update positions\n",
    "    positions += velocities * dt + 0.5 * forces / masses[:, np.newaxis] * dt**2\n",
    "    \n",
    "    # Update velocities (half-step)\n",
    "    velocities += 0.5 * forces / masses[:, np.newaxis] * dt\n",
    "    \n",
    "    # Recompute forces\n",
    "    forces_new = np.zeros_like(forces)\n",
    "    for i in range(n_atoms):\n",
    "        for j in range(i+1, n_atoms):\n",
    "            dr = positions[i] - positions[j]\n",
    "            r = np.linalg.norm(dr)\n",
    "            if r < 5.0:\n",
    "                sig2, eps = 1.0, 0.1\n",
    "                r6, r12 = r**6, r6**2\n",
    "                if r > 1e-8:\n",
    "                    f_mag = 24 * eps * (2 * sig2 / r12 - sig2 / r6) / r\n",
    "                    forces_new[i] -= f_mag * dr\n",
    "                    forces_new[j] += f_mag * dr\n",
    "    \n",
    "    # Update velocities (full-step)\n",
    "    velocities += 0.5 * forces_new / masses[:, np.newaxis] * dt\n",
    "    forces = forces_new\n",
    "    \n",
    "    # Periodically update depth (every 10 steps)\n",
    "    if t % 10 == 0:\n",
    "        force_mag = np.linalg.norm(forces, axis=1)\n",
    "        energy_grad = force_mag  # Simplified: energy gradient ~ force\n",
    "        uncertainty = np.random.rand(n_atoms) * 0.1\n",
    "        local_density = np.array([np.sum(np.linalg.norm(positions[i] - positions[:i], axis=1) < 3.0) for i in range(n_atoms)])\n",
    "        charge_mag = np.abs(np.random.random(n_atoms) * 0.01)\n",
    "        \n",
    "        importance = np.zeros(n_atoms)\n",
    "        for i in range(n_atoms):\n",
    "            importance[i] = 0.4 * (force_mag[i] / 1.0) + 0.3 * (energy_grad[i] / 1.0) + \\\n",
    "                           0.2 * uncertainty[i] + 0.1 * (local_density[i] / 5.0)\n",
    "        \n",
    "        # Update depths based on importance\n",
    "        for i in range(n_atoms):\n",
    "            if importance[i] > 0.8:\n",
    "                depths[i] = 4\n",
    "            elif importance[i] > 0.6:\n",
    "                depths[i] = 3\n",
    "            elif importance[i] > 0.4:\n",
    "                depths[i] = 2\n",
    "            elif importance[i] > 0.2:\n",
    "                depths[i] = 1\n",
    "            else:\n",
    "                depths[i] = 0\n",
    "        \n",
    "        # Record depth history\n",
    "        for d in range(5):\n",
    "            depth_history[d].append(int((depths == d).sum().item()))\n",
    "        \n",
    "        # Calculate energy (simplified)\n",
    "        e = sum(0.5 * masses[i] * np.sum(velocities[i]**2) for i in range(n_atoms))\n",
    "        energies.append(e)\n",
    "\n",
    "print(f\"Simulation complete: {n_timesteps} timesteps, {n_atoms} atoms\")\n",
    "print(f\"Final energy: {energies[-1]:.4f}\")\n",
    "print(f\"Energy change: {energies[-1] - energies[0]:.6f}\")"
   ]
  },
  {
