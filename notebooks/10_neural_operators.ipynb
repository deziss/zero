    "## 1. FNO Architecture Deep Dive\n",
    "\n",
    "FNO works in Fourier space:\n",
    "1. Transform field to frequency domain (rfft)\n",
    "2. Apply linear operator on each frequency mode\n",
    "3. Transform back (irfft)\n",
    "4. Nonlinear activation\n",
    "\n",
    "Key advantage: learns CONTINUOUS operators, works on any grid resolution."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualize FNO architecture\n",
    "fig, axes = plt.subplots(1, 3, figsize=(18, 5))\n",
    "\n",
    "# FNO diagram\n",
    "for ax, (title, y_pos) in zip(axes, [\n",
    "    ('Input Field', 0.9),\n",
    "    ('Fourier + Spectral Conv', 0.5),\n",
    "    ('Output Field', 0.1)\n",
    "]):\n",
    "    ax.text(0.5, y_pos, title, fontsize=16, fontweight='bold',\n",
    "           ha='center', va='center', transform=ax.transAxes)\n",
    "    \n",
    "    # Draw field representation\n",
    "    x = np.linspace(0, 1, 50)\n",
    "    y = np.linspace(0, 1, 50)\n",
    "    X, Y = np.meshgrid(x, y)\n",
    "    Z = np.sin(2*np.pi*X*3) * np.cos(2*np.pi*Y*2) * np.exp(-(X-0.5)**2 - (Y-0.5)**2)\n",
    "\n",
    "    im = ax.imshow(Z, extent=[0,1,0,1], cmap='RdBu_r', alpha=0.8, transform=ax.transAxes)\n",
    "    ax.set_xlim(0, 1)\n",
    "    ax.set_ylim(0, 1)\n",
    "\n",
    "axes[2].text(0.5, 0.05, 'FNO learns: field → field operator',\n",
    "            fontsize=10, ha='center', transform=axes[2].transAxes)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('figs/10_fno_architecture.png', bbox_inches='tight')\n",
    "plt.show()\n",
    "print('FNO architecture visualization saved.')"
   ]
  },
  {
