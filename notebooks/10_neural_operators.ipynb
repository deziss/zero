   "metadata": {},
   "source": [
    "## 2. FNO Model Instantiation and Test\n",
    "\n",
    "Create an FNO model for cell population dynamics:"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create FNO model\n",
    "fno_model = FourierNeuralOperator(\n",
    "    in_channels=5,      # cell density, signaling, nutrients, oxygen, growth\n",
    "    out_channels=5,     # next timestep\n",
    "    latent_dim=64,\n",
    "    modes=16,\n",
    "    width=128,\n",
    "    n_layers=6,\n",
    ").to(device)\n",
    "\n",
    "n_params = sum(p.numel() for p in fno_model.parameters())\n",
    "print(f'FNO model: {n_params:,} parameters')\n",
    "\n",
    "# Test forward pass\n",
    "x = torch.randn(1, 64, 64, 5).to(device)\n",
    "y = fno_model(x)\n",
    "print(f'Input: {x.shape}')\n",
    "print(f'Output: {y.shape}')\n",
    "print(f'Output range: [{y.min():.4f}, {y.max():.4f}]')"
   ]
  },
